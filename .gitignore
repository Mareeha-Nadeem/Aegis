# .gitignore

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter / IPython
.ipynb_checkpoints/
*.ipynb

# Environment variables
.env
.env.*

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Model artefacts (keep directory structure, ignore actual artefact files)
models/setfit/*
!models/setfit/.gitkeep
models/faiss_index/*
!models/faiss_index/.gitkeep

# Data (keep directory structure, ignore actual data files)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/documents/*
!data/documents/.gitkeep

# Logs (keep directory, ignore log files)
logs/*
!logs/.gitkeep

# Test coverage
.coverage
htmlcov/
.pytest_cache/
